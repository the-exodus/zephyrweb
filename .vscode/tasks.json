{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite:dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:\\s+http"
        }
      }
    },
    {
      "label": "vite:stop",
      "type": "shell",
      "command": "pkill -f 'vite' || true"
    }
  ]
}
